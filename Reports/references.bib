	author = {Huber, John H. and Ji, Mengmeng and Shih, Yi-Hsuan and Wang, Mei and Colditz, Graham and Chang, Su-Hsin},
	month = sep,
	year = {2023},
	pages = {5768},
	file = {Huber et al. - 2023 - Disentangling age, gender, and racialethnic dispa.pdf:/Users/langeja/Zotero/storage/47VY3SF5/Huber et al. - 2023 - Disentangling age, gender, and racialethnic dispa.pdf:application/pdf},
}

